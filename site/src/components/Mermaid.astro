---
/**
 * Mermaid diagram component — renders at build time via a pre-rendered SVG approach,
 * or at runtime via a small inline script loading mermaid from CDN.
 */
export interface Props {
  chart: string;
  caption?: string;
}

const { chart, caption } = Astro.props;
const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class="my-8">
  <div
    id={id}
    class="mermaid-container rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 overflow-x-auto"
  >
    <pre class="mermaid">{chart}</pre>
  </div>
  {caption && (
    <figcaption class="mt-2 text-center text-sm text-[var(--color-text-muted)] italic">
      {caption}
    </figcaption>
  )}
</figure>

<script>
  async function initMermaid() {
    if (typeof window === 'undefined') return;
    // @ts-expect-error - loaded from CDN
    if (!window.mermaid) {
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
      script.onload = () => {
        // @ts-expect-error - loaded from CDN
        window.mermaid.initialize({
          startOnLoad: true,
          theme: 'dark',
          themeVariables: {
            primaryColor: '#1c2128',
            primaryTextColor: '#e6edf3',
            primaryBorderColor: '#30363d',
            lineColor: '#39d353',
            secondaryColor: '#161b22',
            tertiaryColor: '#0d1117',
            edgeLabelBackground: '#161b22',
          },
        });
        // @ts-expect-error - loaded from CDN
        window.mermaid.run();
      };
      document.head.appendChild(script);
    } else {
      // @ts-expect-error - loaded from CDN
      window.mermaid.run();
    }
  }
  initMermaid();
</script>
