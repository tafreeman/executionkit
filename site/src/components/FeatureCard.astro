---
export interface Props {
  title: string;
  icon: string;
}

const { title, icon } = Astro.props;
---

<div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 hover:border-[var(--color-accent-dim)] transition-colors">
  <div class="text-3xl mb-3">{icon}</div>
  <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2">{title}</h3>
  <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
    <slot />
  </p>
</div>
